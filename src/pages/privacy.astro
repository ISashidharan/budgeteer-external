---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";

export const prerender = true;
const updated = "June 19, 2026";

const sections = [
  { h: "Overview", p: ["AtlasIQ (\"we\", \"us\") helps you track and grow your personal finances. This policy explains what we collect, why, and the choices you have. We designed AtlasIQ to collect as little as possible and to never sell your data."] },
  { h: "Information we collect", p: ["Account information you provide, such as your name and email address.", "Financial data you choose to add or import — transactions, budgets, loans, and assets. This stays yours and is never sold.", "Usage and device information used to keep the service secure and reliable."] },
  { h: "How we use information", p: ["To provide and improve the AtlasIQ service, secure your account, process subscriptions through our payment provider, and respond to your requests. We do not use your financial data for advertising."] },
  { h: "Payments", p: ["Subscription payments are processed by Stripe. We never see or store your full card details. Stripe's handling of payment data is governed by its own privacy policy."] },
  { h: "Data security", p: ["We protect your information with encryption in transit and at rest, strict access controls, and ongoing monitoring. No system is perfectly secure, but safeguarding your data is foundational to everything we build."] },
  { h: "Your choices", p: ["You can access, export, or delete your data at any time from your account, or by contacting us. Deleting your account permanently removes your financial data from our active systems."] },
  { h: "Contact", p: [`Questions about privacy? Email us at ${SITE.email}.`] },
];
---

<BaseLayout title="Privacy Policy" description="How AtlasIQ collects, uses, and protects your data." noindex={true}>
  <section class="container-page max-w-3xl py-16 sm:py-20">
    <h1 class="text-4xl font-bold sm:text-5xl">Privacy Policy</h1>
    <p class="mt-3 text-sm text-ink-soft">Last updated: {updated}</p>
    <div class="mt-10 space-y-8">
      {sections.map((s) => (
        <section>
          <h2 class="text-xl font-bold text-ink">{s.h}</h2>
          {s.p.map((para) => (
            <p class="mt-3 leading-relaxed text-ink-soft">{para}</p>
          ))}
        </section>
      ))}
    </div>
    <p class="mt-12 rounded-xl border border-ink/10 bg-cream-paper p-5 text-sm leading-relaxed text-ink-soft">
      This page is a starting template and not legal advice. Have it reviewed by a
      qualified professional before launch.
    </p>
  </section>
</BaseLayout>
