---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import FAQ from "../components/FAQ.astro";
import CtaBand from "../components/CtaBand.astro";
import PricingCards from "../components/PricingCards.tsx";
import { SITE } from "../lib/site";

export const prerender = true;

const faqs = [
  { q: "Can I switch plans later?", a: "Yes — upgrade or downgrade anytime from your account. Changes are prorated automatically." },
  { q: "What payment methods do you accept?", a: "All major credit and debit cards via Stripe, our secure payments processor. We never see or store your card details." },
  { q: "Is the free plan really free?", a: "Forever. Starter has no time limit and requires no card. Upgrade only when you want the advanced tools." },
  { q: "Do you offer refunds?", a: "Annual plans come with a 14-day money-back guarantee. If AtlasIQ isn't for you, email us within 14 days for a full refund." },
  { q: "Can I cancel anytime?", a: "Of course. Cancel in a single click — you'll keep access until the end of your billing period." },
  { q: "Do you offer team or business accounts?", a: "Yes — we offer volume-discounted seat bundles, centralized billing, and admin controls for teams of any size. Contact our sales team for a custom quote tailored to your headcount and needs." },
  { q: "Can our company be invoiced instead of paying by card?", a: "Absolutely. Enterprise customers can pay via bank transfer with annual invoicing, PO numbers, and flexible payment terms. Reach out to discuss what works for your procurement process." },
  { q: "Can we offer AtlasIQ as an employee financial-wellness benefit?", a: "Many companies include AtlasIQ in their benefits package to help employees take control of their finances. We offer bulk seat pricing and dedicated onboarding for HR rollouts — email us to learn more." },
];

const b2bBenefits = [
  {
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 1-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    title: "Team management",
    body: "Add or remove seats from a single admin dashboard. One invoice, zero per-user billing chaos.",
  },
  {
    icon: '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
    title: "Volume discounts",
    body: "Save progressively more as your team grows. 10+ seats start at 20% off list price — ask about larger tiers.",
  },
  {
    icon: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
    title: "Flexible billing",
    body: "Annual invoicing, PO numbers, bank transfer, and custom payment terms — built for your procurement process.",
  },
  {
    icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.83-.83a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
    title: "Dedicated onboarding",
    body: "Live setup session with your team plus a named account contact for questions going forward.",
  },
  {
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
    title: "SLA-backed support",
    body: "4-hour guaranteed response times, priority escalation, and a private channel direct to our team.",
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6m-6 4h6m-6 4h4"/>',
    title: "Custom contract terms",
    body: "Bring your own MSA, DPA, or security questionnaire. SOC 2 documentation available on request.",
  },
];

const compare = [
  { feature: "Connected accounts", free: "2", pro: "Unlimited", auto: "Unlimited", ai: "Unlimited" },
  { feature: "Budgets", free: "1", pro: "Unlimited", auto: "Unlimited", ai: "Unlimited" },
  { feature: "CSV / XLSX import", free: "—", pro: "✓", auto: "✓", ai: "✓" },
  { feature: "Analytics & trends", free: "Basic", pro: "Full", auto: "Full", ai: "Advanced" },
  { feature: "Loan tracking", free: "—", pro: "✓", auto: "✓", ai: "✓" },
  { feature: "Budget projections", free: "—", pro: "✓", auto: "✓", ai: "✓" },
  { feature: "Automatic imports & sync", free: "—", pro: "—", auto: "✓", ai: "✓" },
  { feature: "Auto-categorization rules", free: "—", pro: "—", auto: "✓", ai: "✓" },
  { feature: "Asset / portfolio tracking", free: "Snapshot", pro: "Snapshot", auto: "✓", ai: "✓" },
  { feature: "AI insights & coaching", free: "—", pro: "—", auto: "—", ai: "✓" },
  { feature: "Net-worth forecasting", free: "—", pro: "—", auto: "—", ai: "✓" },
  { feature: "Priority support", free: "—", pro: "—", auto: "—", ai: "✓" },
];
---

<BaseLayout
  title="Pricing"
  description="Simple, honest pricing. Start free, upgrade when you're ready. No hidden fees — cancel anytime."
>
  <section class="bg-hero-glow">
    <div class="container-page py-16 text-center sm:py-20">
      <span class="eyebrow" data-reveal>Pricing</span>
      <h1 class="mx-auto mt-5 max-w-2xl text-4xl font-bold sm:text-5xl" data-reveal data-reveal-delay="60">
        Simple pricing that grows with you
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-ink-soft" data-reveal data-reveal-delay="120">
        Start free, forever. Upgrade only when you want the advanced tools — and
        cancel anytime.
      </p>
    </div>
  </section>

  <Section class="!pt-4">
    <PricingCards client:load />
  </Section>

  <!-- B2B / Teams section -->
  <Section id="business" eyebrow="For teams &amp; businesses" title="AtlasIQ at scale" subtitle="Give your whole team the tools to budget smarter — with admin controls, centralized billing, and pricing that grows with you.">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-reveal>
      {b2bBenefits.map((b) => (
        <div class="card flex gap-4 p-6">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-teal-400/15 to-teal-600/10 text-teal-600">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={b.icon} />
          </span>
          <div>
            <h3 class="font-semibold text-ink">{b.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-ink-soft">{b.body}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="relative mt-10 overflow-hidden rounded-3xl" data-reveal>
      <div
        class="relative px-8 py-14 text-center sm:px-16"
        style="background-image: linear-gradient(135deg, #312E81 0%, #4F46E5 50%, #6366F1 100%);"
      >
        <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-white/10 blur-2xl"></div>
        <div class="pointer-events-none absolute -bottom-16 -left-16 h-64 w-64 rounded-full bg-teal-900/40 blur-2xl"></div>
        <div class="relative">
          <p class="text-sm font-bold uppercase tracking-widest text-teal-200">Custom pricing</p>
          <h3 class="mt-3 text-2xl font-bold text-white sm:text-3xl">
            Ready to roll out AtlasIQ to your team?
          </h3>
          <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-white/80">
            Tell us your team size and goals — we'll put together a custom quote within one business day.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href="/contact"
              class="btn rounded-full bg-white px-7 py-3.5 font-bold text-teal-700 shadow-lg transition-transform hover:-translate-y-0.5"
            >
              Talk to sales
            </a>
            <a
              href={`mailto:${SITE.email}?subject=Business%20pricing%20enquiry`}
              class="btn rounded-full border border-white/40 px-7 py-3.5 font-bold text-white transition-colors hover:bg-white/10"
            >
              Email us directly
            </a>
          </div>
          <p class="mt-5 text-xs text-white/60">No commitment required · Typically reply within one business day</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Comparison table -->
  <Section eyebrow="Compare" title="Every plan, side by side">
    <div class="overflow-x-auto" data-reveal>
      <table class="w-full min-w-[720px] overflow-hidden rounded-2xl border border-ink/10 bg-cream-paper text-left text-sm">
        <thead>
          <tr class="border-b border-ink/10 bg-ink/[0.02]">
            <th class="px-5 py-4 font-bold text-ink">Feature</th>
            <th class="px-5 py-4 font-bold text-ink">Free</th>
            <th class="px-5 py-4 font-bold text-ink">Pro</th>
            <th class="px-5 py-4 font-bold text-teal-600">Auto</th>
            <th class="px-5 py-4 font-bold text-ink">AI</th>
          </tr>
        </thead>
        <tbody>
          {compare.map((row) => (
            <tr class="border-b border-ink/5 last:border-0">
              <td class="px-5 py-3.5 font-semibold text-ink">{row.feature}</td>
              <td class="px-5 py-3.5 text-ink-soft">{row.free}</td>
              <td class="px-5 py-3.5 text-ink-soft">{row.pro}</td>
              <td class="px-5 py-3.5 font-medium text-ink">{row.auto}</td>
              <td class="px-5 py-3.5 text-ink-soft">{row.ai}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <Section eyebrow="Questions" title="Pricing FAQ" class="!pt-0">
    <div data-reveal>
      <FAQ items={faqs} />
    </div>
  </Section>

  <CtaBand title="Try AtlasIQ free today" subtitle="No card required. Upgrade only when you're ready." />
</BaseLayout>
