---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SIGN_UP_URL } from "../lib/site";

// Server-rendered so we can confirm the Checkout Session with Stripe.
export const prerender = false;

const sessionId = Astro.url.searchParams.get("session_id");
let email: string | null = null;
let planLabel: string | null = null;

if (sessionId && import.meta.env.STRIPE_SECRET_KEY) {
  try {
    const { getStripe } = await import("../lib/stripe");
    const session = await getStripe().checkout.sessions.retrieve(sessionId, {
      expand: ["subscription"],
    });
    email = session.customer_details?.email ?? null;
    const meta = (session.subscription as any)?.metadata;
    planLabel = meta?.plan
      ? meta.plan.charAt(0).toUpperCase() + meta.plan.slice(1)
      : null;
  } catch (err) {
    console.error("[success] could not retrieve session:", err);
  }
}
---

<BaseLayout title="You're in!" description="Your Budgeteer subscription is active." noindex={true}>
  <section class="container-page flex min-h-[70vh] max-w-2xl flex-col items-center justify-center py-20 text-center">
    <div class="grid h-20 w-20 place-items-center rounded-full bg-gradient-to-br from-teal-400 to-teal-600 text-white shadow-glow animate-float">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>

    <h1 class="mt-8 text-4xl font-bold sm:text-5xl">You're all set! 🎉</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-soft">
      {planLabel ? `Your Budgeteer ${planLabel} subscription is active.` : "Your Budgeteer subscription is active."}
      {email ? ` A receipt is on its way to ${email}.` : ""}
    </p>

    <div class="mt-8 w-full max-w-md rounded-2xl border border-ink/10 bg-cream-paper p-6 text-left shadow-card">
      <h2 class="font-serif text-lg font-bold text-ink">One quick step left</h2>
      <p class="mt-2 text-sm leading-relaxed text-ink-soft">
        Create your Budgeteer account{email ? ` with ${email}` : ""} to unlock your
        new plan and start tracking your money.
      </p>
      <a href={SIGN_UP_URL} class="btn-primary mt-5 w-full">Create my account</a>
    </div>

    <a href="/" class="mt-8 text-sm font-semibold text-teal-600 hover:underline">← Back to home</a>
  </section>
</BaseLayout>
