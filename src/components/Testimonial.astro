---
interface Props {
  quote: string;
  name: string;
  role: string;
  /** Two-letter initials for the avatar. */
  initials: string;
  accent?: "teal" | "coin";
}
const { quote, name, role, initials, accent = "teal" } = Astro.props;
const avatar =
  accent === "coin"
    ? "bg-gradient-to-br from-coin-400 to-coin-600"
    : "bg-gradient-to-br from-teal-400 to-teal-600";
---

<figure class="card flex h-full flex-col p-6">
  <div class="text-coin-500" aria-hidden="true">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor">
      <path d="M9.5 7C6.5 7 4 9.5 4 12.5V19h6v-6H7c0-2 1.2-3.5 2.5-4L9.5 7zm10 0C16.5 7 14 9.5 14 12.5V19h6v-6h-3c0-2 1.2-3.5 2.5-4L19.5 7z"></path>
    </svg>
  </div>
  <blockquote class="mt-3 flex-1 text-[1.02rem] leading-relaxed text-ink">
    “{quote}”
  </blockquote>
  <figcaption class="mt-6 flex items-center gap-3">
    <span
      class={`grid h-11 w-11 place-items-center rounded-full text-sm font-bold text-white ${avatar}`}
      >{initials}</span
    >
    <span>
      <span class="block font-semibold text-ink">{name}</span>
      <span class="block text-sm text-ink-soft">{role}</span>
    </span>
  </figcaption>
</figure>
