---
/** A row of headline metrics that count up when scrolled into view. */
interface Stat {
  value: string;
  label: string;
}
interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---

<div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-ink/10 bg-ink/10 sm:grid-cols-4">
  {
    stats.map((s) => (
      <div class="bg-cream-paper px-4 py-7 text-center">
        <div class="font-serif text-3xl font-bold text-gradient-teal sm:text-4xl">
          {s.value}
        </div>
        <div class="mt-1 text-sm font-medium text-ink-soft">{s.label}</div>
      </div>
    ))
  }
</div>
