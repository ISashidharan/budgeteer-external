---
import { SIGN_UP_URL } from "../lib/site";
interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = "Start growing your wealth today",
  subtitle = "Join people taking control of their money with Budgeteer. Free to start — no card required.",
} = Astro.props;
---

<section class="py-16 sm:py-24">
  <div class="container-page">
    <div
      class="relative overflow-hidden rounded-3xl px-6 py-14 text-center shadow-float sm:px-12 sm:py-20"
      style="background-image: linear-gradient(120deg, #0F766E 0%, #0D9488 55%, #14B8A6 100%);"
    >
      <div
        class="pointer-events-none absolute -right-16 -top-16 h-72 w-72 rounded-full bg-white/10 blur-2xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-20 -left-10 h-72 w-72 rounded-full bg-coin-500/20 blur-2xl"
      >
      </div>
      <div class="relative mx-auto max-w-2xl">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">{title}</h2>
        <p class="mt-4 text-lg leading-relaxed text-white/85">{subtitle}</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={SIGN_UP_URL}
            class="btn rounded-full bg-white px-7 py-3.5 text-teal-700 shadow-lg transition-transform hover:-translate-y-0.5"
            >Get started free</a
          >
          <a
            href="/pricing"
            class="btn rounded-full border border-white/40 px-7 py-3.5 text-white transition-colors hover:bg-white/10"
            >View pricing</a
          >
        </div>
      </div>
    </div>
  </div>
</section>
