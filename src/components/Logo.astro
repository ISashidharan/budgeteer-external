---
/**
 * Inline AtlasIQ logo (mark + optional wordmark). Mirrors the app's
 * favicon.svg so the brand reads identically across site and product.
 *
 * The mark is an indigo tile holding a predictive trend line that rises into
 * a dashed forecast and a cyan node out ahead — "intelligent, predictive"
 * at a glance.
 */
interface Props {
  /** Pixel size of the square mark. */
  size?: number;
  /** Show the "AtlasIQ" wordmark next to the mark. */
  withText?: boolean;
  class?: string;
}
const { size = 36, withText = true, class: className = "" } = Astro.props;
const r = size; // viewBox is square
---

<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg
    width={r}
    height={r}
    viewBox="0 0 512 512"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="AtlasIQ"
    class="shrink-0"
  >
    <defs>
      <linearGradient id="lg-tile" x1="64" y1="48" x2="448" y2="464" gradientUnits="userSpaceOnUse">
        <stop stop-color="#6366F1"></stop>
        <stop offset="0.55" stop-color="#4F46E5"></stop>
        <stop offset="1" stop-color="#4338CA"></stop>
      </linearGradient>
      <linearGradient id="lg-line" x1="120" y1="360" x2="392" y2="150" gradientUnits="userSpaceOnUse">
        <stop stop-color="#A5B4FC"></stop>
        <stop offset="1" stop-color="#22D3EE"></stop>
      </linearGradient>
    </defs>
    <rect x="32" y="32" width="448" height="448" rx="112" fill="url(#lg-tile)"></rect>
    <!-- Predictive trend: a solid history that continues as a dashed forecast. -->
    <path
      d="M120 348 L206 286 L268 318 L344 196"
      stroke="url(#lg-line)"
      stroke-width="26"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"></path>
    <path
      d="M344 196 L388 162"
      stroke="#22D3EE"
      stroke-width="26"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-dasharray="2 46"
      fill="none"></path>
    <!-- Forecast node — the cyan "IQ" spark out ahead of the curve. -->
    <circle cx="392" cy="158" r="30" fill="#22D3EE"></circle>
    <circle cx="392" cy="158" r="13" fill="#0B1020"></circle>
  </svg>
  {
    withText && (
      <span class="font-serif text-xl font-bold tracking-tight text-ink">
        Atlas<span class="text-gradient-teal">IQ</span>
      </span>
    )
  }
</span>
