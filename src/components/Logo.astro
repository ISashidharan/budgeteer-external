---
/**
 * Inline AtlasIQ logo (mark + optional wordmark). Mirrors the app's
 * favicon.svg so the brand reads identically across site and product.
 *
 * The mark is an indigo tile holding a compass rose — "map your financial
 * future" — with the North point tipped in brand cyan.
 */
interface Props {
  /** Pixel size of the square mark. */
  size?: number;
  /** Show the "AtlasIQ" wordmark next to the mark. */
  withText?: boolean;
  class?: string;
}
const { size = 36, withText = true, class: className = "" } = Astro.props;
const r = size; // viewBox is square
---

<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg
    width={r}
    height={r}
    viewBox="0 0 512 512"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="AtlasIQ"
    class="shrink-0"
  >
    <defs>
      <linearGradient id="lg-tile" x1="64" y1="48" x2="448" y2="464" gradientUnits="userSpaceOnUse">
        <stop stop-color="#6366F1"></stop>
        <stop offset="0.55" stop-color="#4F46E5"></stop>
        <stop offset="1" stop-color="#4338CA"></stop>
      </linearGradient>
      <linearGradient id="lg-sheen" x1="80" y1="60" x2="300" y2="360" gradientUnits="userSpaceOnUse">
        <stop stop-color="#FFFFFF" stop-opacity="0.22"></stop>
        <stop offset="1" stop-color="#FFFFFF" stop-opacity="0"></stop>
      </linearGradient>
    </defs>
    <rect x="32" y="32" width="448" height="448" rx="112" fill="url(#lg-tile)"></rect>
    <rect x="32" y="32" width="448" height="448" rx="112" fill="url(#lg-sheen)"></rect>

    <!-- Compass rose: cardinal points in white, North tipped in brand cyan. -->
    <circle cx="256" cy="256" r="206" fill="none" stroke="#FFFFFF" stroke-opacity="0.5" stroke-width="6"></circle>
    <circle cx="256" cy="256" r="186" fill="none" stroke="#FFFFFF" stroke-opacity="0.2" stroke-width="2"></circle>

    <!-- Intercardinal star -->
    <path d="M362.1 149.9 L256 216 L256 256 Z" fill="#FFFFFF" fill-opacity="0.30"></path>
    <path d="M362.1 149.9 L256 256 L296 256 Z" fill="#FFFFFF" fill-opacity="0.18"></path>
    <path d="M362.1 362.1 L296 256 L256 256 Z" fill="#FFFFFF" fill-opacity="0.30"></path>
    <path d="M362.1 362.1 L256 256 L256 296 Z" fill="#FFFFFF" fill-opacity="0.18"></path>
    <path d="M149.9 362.1 L256 296 L256 256 Z" fill="#FFFFFF" fill-opacity="0.30"></path>
    <path d="M149.9 362.1 L256 256 L216 256 Z" fill="#FFFFFF" fill-opacity="0.18"></path>
    <path d="M149.9 149.9 L216 256 L256 256 Z" fill="#FFFFFF" fill-opacity="0.30"></path>
    <path d="M149.9 149.9 L256 256 L256 216 Z" fill="#FFFFFF" fill-opacity="0.18"></path>

    <!-- Cardinal star: East / South / West -->
    <path d="M452 256 L287.1 224.9 L256 256 Z" fill="#FFFFFF"></path>
    <path d="M452 256 L256 256 L287.1 287.1 Z" fill="#FFFFFF" fill-opacity="0.6"></path>
    <path d="M256 452 L256 256 L224.9 287.1 Z" fill="#FFFFFF"></path>
    <path d="M256 452 L287.1 287.1 L256 256 Z" fill="#FFFFFF" fill-opacity="0.6"></path>
    <path d="M60 256 L224.9 287.1 L256 256 Z" fill="#FFFFFF"></path>
    <path d="M60 256 L256 256 L224.9 224.9 Z" fill="#FFFFFF" fill-opacity="0.6"></path>

    <!-- North point — brand cyan -->
    <path d="M256 60 L256 256 L287.1 224.9 Z" fill="#67E8F9"></path>
    <path d="M256 60 L224.9 224.9 L256 256 Z" fill="#22D3EE"></path>

    <!-- Center jewel -->
    <circle cx="256" cy="256" r="26" fill="#FFFFFF"></circle>
    <circle cx="256" cy="256" r="10" fill="#22D3EE"></circle>
  </svg>
  {
    withText && (
      <span class="font-serif text-xl font-bold tracking-tight text-ink">
        Atlas<span class="text-gradient-teal">IQ</span>
      </span>
    )
  }
</span>
