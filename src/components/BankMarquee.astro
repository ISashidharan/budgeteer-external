---
/**
 * "Works with your bank" — a single seamless marquee of bank/brand wordmarks.
 * These are generic, illustrative names (no real logos) styled as monochrome
 * pills so the row reads as broad compatibility rather than endorsement.
 */
const banks = [
  "Chase", "Bank of America", "Wells Fargo", "Citi", "Capital One",
  "American Express", "Discover", "US Bank", "PNC", "Ally",
  "Charles Schwab", "Fidelity", "SoFi", "Truist", "Barclays",
];
---

<div class="marquee-mask overflow-hidden">
  <div class="marquee-track flex w-max items-center gap-3 animate-marquee">
    {[...banks, ...banks].map((b) => (
      <span class="flex shrink-0 items-center gap-2 rounded-full border border-ink/10 bg-cream-paper px-4 py-2 text-sm font-semibold text-ink-soft">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-600">
          <path d="M3 21h18" />
          <path d="M5 21V10l7-5 7 5v11" />
          <path d="M9 21v-6h6v6" />
        </svg>
        {b}
      </span>
    ))}
  </div>
</div>
