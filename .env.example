# ── Site ────────────────────────────────────────────────────────────────────
# Public URL of this marketing site (used for canonical links, OG tags, sitemap)
SITE_URL=https://atlasiq.app

# Where "Sign in" / "Get started" / post-checkout CTAs send users — the AtlasIQ app.
PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ──────────────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys (use TEST keys in development)
STRIPE_SECRET_KEY=sk_test_xxx
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# From `stripe listen` or the Stripe dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Recurring Price IDs created in the Stripe dashboard (Products → Pricing).
# Each paid plan needs a monthly and a yearly price. (Free has no price.)
# Launch pricing (the Auto tier is hidden — AUTO_ENABLED in src/lib/plans.ts):
#   Pro  $4.99/mo  ($49.90/yr)
#   AI   $7.99/mo  ($79.90/yr)
# Auto's prices are kept (unused at launch) for when Auto is re-enabled:
#   Auto $9.99/mo  ($99.90/yr)   ·   AI (full lineup) $14.99/mo ($149.90/yr)
PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxx
PUBLIC_STRIPE_PRICE_AUTO_MONTHLY=price_xxx
PUBLIC_STRIPE_PRICE_AUTO_YEARLY=price_xxx
PUBLIC_STRIPE_PRICE_AI_MONTHLY=price_xxx
PUBLIC_STRIPE_PRICE_AI_YEARLY=price_xxx
