# ── Site ────────────────────────────────────────────────────────────────────
# Public URL of this marketing site (used for canonical links, OG tags, sitemap)
SITE_URL=https://atlasiq.app

# Where "Sign in" / "Get started" / pricing CTAs send users — the AtlasIQ app.
# The pricing buttons hand off to ${PUBLIC_APP_URL}/register?plan=…&period=…,
# and the app owns the actual Stripe Checkout, so this site needs no Stripe keys.
PUBLIC_APP_URL=http://localhost:3000
