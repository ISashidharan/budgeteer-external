# ── Site ────────────────────────────────────────────────────────────────────
# Public URL of this marketing site (used for canonical links, OG tags, sitemap)
SITE_URL=https://budgeteer.app

# Where "Sign in" / "Get started" / post-checkout CTAs send users — the Budgeteer app.
PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ──────────────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys (use TEST keys in development)
STRIPE_SECRET_KEY=sk_test_xxx
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# From `stripe listen` or the Stripe dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Recurring Price IDs created in the Stripe dashboard (Products → Pricing).
# Each plan needs a monthly and a yearly price.
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_WEALTH_MONTHLY=price_xxx
STRIPE_PRICE_WEALTH_YEARLY=price_xxx
